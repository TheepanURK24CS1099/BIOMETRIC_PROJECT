# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hostel_attendance?schema=public"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="8h"

# App
NEXT_PUBLIC_APP_NAME="Girls Hostel Attendance System"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMS - Fast2SMS (India)
FAST2SMS_API_KEY="your-fast2sms-api-key"
FAST2SMS_SENDER_ID="HSTEL"

# WhatsApp - Fast2SMS
WHATSAPP_PROVIDER="fast2sms"
FAST2SMS_WHATSAPP_PHONE_NUMBER_ID="your-whatsapp-phone-number-id"
FAST2SMS_WHATSAPP_TEMPLATE="attendance_update"
WHATSAPP_SERVICE_URL="http://localhost:3001/send-whatsapp"

# SMS - Twilio (International)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# SMS Provider: "fast2sms" | "twilio" | "mock"
SMS_PROVIDER="mock"

# Auto-absent cron time (24h format)
AUTO_ABSENT_TIME="22:00"
ATTENDANCE_CUTOFF_TIME="22:00"

# Upload
MAX_FILE_SIZE="5242880"
UPLOAD_DIR="public/uploads"
