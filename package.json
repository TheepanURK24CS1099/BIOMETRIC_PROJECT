{
  "name": "girls-hostel-biometric-attendance",
  "version": "1.0.0",
  "description": "Girls Hostel Biometric Attendance System",
  "scripts": {
    "dev": "prisma generate --schema backend/prisma/schema.prisma && next dev",
    "build": "prisma generate --schema backend/prisma/schema.prisma && next build",
    "start": "next start",
    "postinstall": "prisma generate --schema backend/prisma/schema.prisma",
    "lint": "next lint",
    "db:push": "prisma db push --schema backend/prisma/schema.prisma",
    "db:studio": "prisma studio --schema backend/prisma/schema.prisma",
    "db:seed": "tsx backend/prisma/seed.ts",
    "db:migrate": "prisma migrate deploy --schema backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.3.1",
    "jose": "^5.2.3",
    "next": "^14.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "sharp": "^0.33.2",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "prisma": "^5.10.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
